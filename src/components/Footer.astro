---
const currentYear = new Date().getFullYear();
const footerLinks = [
  { name: 'Inicio', href: '#inicio' },
  { name: 'Nosotros', href: '#nosotros' },
  { name: 'Servicios', href: '#servicios' },
  { name: 'Planes', href: '#planes' },
  { name: 'Consultorio', href: '#consultorio' },
];
---

<footer class="bg-[#003366] text-white pt-20 pb-10 px-6 font-montserrat relative overflow-hidden">
  <div class="absolute top-0 left-0 w-full overflow-hidden leading-[0] transform rotate-180">
    <svg class="relative block w-[calc(100%+1.3px)] h-[50px]" data-name="Layer 1" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 120" preserveAspectRatio="none">
        <path d="M321.39,56.44c58-10.79,114.16-30.13,172-41.86,82.39-16.72,168.19-17.73,250.45-.39C823.78,31,906.67,72,985.66,92.83c70.05,18.48,146.53,26.09,214.34,3V0H0V27.35A600.21,600.21,0,0,0,321.39,56.44Z" fill="#FFFFFF"></path>
    </svg>
  </div>

  <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 relative z-10">
    
    <div class="space-y-6">
      <img src="/images/logo.svg" alt="Sima24 Logo" class="h-12 w-auto" />
      <p class="text-blue-100 text-sm leading-relaxed opacity-80">
        Comprometidos con la salud de las familias venezolanas, ofreciendo soporte vital avanzado y atención médica integral las 24 horas del día.
      </p>
      <div class="flex gap-4">
        <a href="#" class="p-2 bg-white/10 rounded-full hover:bg-[#0056b3] transition-colors">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
        </a>
        <a href="#" class="p-2 bg-white/10 rounded-full hover:bg-[#0056b3] transition-colors">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
        </a>
      </div>
    </div>

    <div class="space-y-6">
      <h3 class="text-lg font-bold border-l-4 border-[#0056b3] pl-4">Navegación</h3>
      <ul class="space-y-3">
        {footerLinks.map(link => (
          <li>
            <a href={link.href} class="text-blue-100 hover:text-[#0056b3] transition-colors text-sm flex items-center gap-2">
              <span class="text-[#0056b3]">›</span> {link.name}
            </a>
          </li>
        ))}
      </ul>
    </div>

    <div class="space-y-6">
      <h3 class="text-lg font-bold border-l-4 border-[#0056b3] pl-4">Contacto</h3>
      <div class="space-y-4 text-sm text-blue-100">
        <p class="flex items-start gap-3">
          <svg class="w-5 h-5 text-[#0056b3]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          Sector El Carmen, Av. 11, Calle 1, El Vigía.
        </p>
        <p class="flex items-center gap-3">
          <svg class="w-5 h-5 text-[#0056b3]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          +58 275-1234567
        </p>
        <p class="flex items-center gap-3 font-bold text-white bg-white/5 p-3 rounded-xl border border-white/10">
          <span class="w-2 h-2 bg-red-500 rounded-full animate-ping"></span>
          Emergencias: 0800-SIMA-911
        </p>
      </div>
    </div>

    <div class="space-y-6">
      <h3 class="text-lg font-bold border-l-4 border-[#0056b3] pl-4">Afiliación Online</h3>
      <p class="text-sm text-blue-100 italic">Recibe información sobre jornadas médicas y nuevos convenios.</p>
      <form id="subscription-form" class="flex flex-col gap-3">
        <input
          id="email-input"
          type="email"
          placeholder="Tu correo electrónico"
          required
          class="bg-white/10 border border-white/20 rounded-lg px-4 py-2 text-sm focus:outline-none focus:border-[#0056b3]"
        />
        <button type="submit" class="bg-[#0056b3] text-white font-bold py-2 rounded-lg hover:bg-white hover:text-[#0056b3] transition-all">
          Afiliarme
        </button>
      </form>
      <div id="success-message" class="hidden bg-green-500/20 border border-green-400 text-green-100 px-4 py-3 rounded-lg text-sm flex items-center gap-2">
        <svg class="w-5 h-5 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
        </svg>
        ¡Afiliación exitosa! Pronto recibirás noticias.
      </div>
    </div>
  </div>

  <div class="max-w-7xl mx-auto mt-20 pt-8 border-t border-white/10 flex flex-col md:flex-row justify-between items-center gap-4 text-xs text-blue-200/60">
    <p>© {currentYear} Sima24 C.A. Todos los derechos reservados.</p>
    <div class="flex gap-6">
      <a href="#" class="hover:text-white transition-colors">Términos y Condiciones</a>
      <a href="#" class="hover:text-white transition-colors">Política de Privacidad</a>
    </div>
  </div>
</footer>

<script>
  const form = document.getElementById('subscription-form') as HTMLFormElement;
  const successMessage = document.getElementById('success-message') as HTMLDivElement;
  const emailInput = document.getElementById('email-input') as HTMLInputElement;

  form?.addEventListener('submit', (e) => {
    e.preventDefault();

    if (emailInput.value && emailInput.checkValidity()) {
      // Ocultar formulario y mostrar mensaje de éxito
      form.classList.add('hidden');
      successMessage.classList.remove('hidden');

      // Resetear después de 5 segundos
      setTimeout(() => {
        form.classList.remove('hidden');
        successMessage.classList.add('hidden');
        emailInput.value = '';
      }, 5000);
    }
  });
</script>