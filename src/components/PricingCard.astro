---
// src/components/PricingCard.astro
const { title, subtitle, features } = Astro.props;
---

<div class="pricing-card-inner group flex flex-col h-full w-full overflow-hidden p-8 rounded-2xl border-2 transition-all duration-500 shadow-sm bg-white border-blue-400 text-gray-800 lg:hover:bg-[#0056b3] lg:hover:border-[#0056b3] lg:hover:text-white lg:hover:scale-105 lg:hover:shadow-xl">
  
  <div class=" text-center mb-6">
    <h3 class="text-xl font-bold font-montserrat leading-tight min-h-[60px] flex items-center justify-center">
      {title}
    </h3>
    {subtitle && <p class="mt-4 text-xs font-montserrat text-black group-hover:text-blue-100 transition-colors">
      {subtitle}
    </p>}
  </div>

  <ul class="space-y-4 mb-10 flex-grow">
    {features.map((feature) => (
      <li class="flex items-start gap-3 text-sm font-montserrat">
        <svg class="w-5 h-5 mt-0.5 shrink-0 text-black group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"></path>
        </svg>
        <span class="leading-tight">{feature}</span>
      </li>
    ))}
  </ul>

  <a href="#" class="btn-pricing py-3 px-6 rounded-lg font-bold flex items-center justify-center gap-2 transition-colors border-2 border-[#003366] text-[#003366] group-hover:bg-white group-hover:text-[#0056b3] group-hover:border-white">
    Solicitar cita
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
  </a>
</div>