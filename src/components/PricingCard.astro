---
const { title, subtitle, features, isFeatured = false } = Astro.props;
---

<div class={`flex flex-col p-8 rounded-2xl border-2 transition-all duration-300 hover:shadow-xl ${
  isFeatured 
  ? 'bg-[#0056b3] border-[#0056b3] text-white' 
  : 'bg-white border-blue-400 text-gray-800'
}`}>
  <div class="text-center mb-6">
    <h3 class="text-xl font-bold font-montserrat leading-tight min-h-[60px] flex items-center justify-center">
      {title}
    </h3>
    {subtitle && <p class={`mt-4 text-xs font-montserrat ${isFeatured ? 'text-blue-100' : 'text-gray-500'}`}>
      {subtitle}
    </p>}
  </div>

  <ul class="space-y-4 mb-10 flex-grow">
    {features.map((feature) => (
      <li class="flex items-start gap-3 text-sm font-montserrat">
        <svg class={`w-5 h-5 mt-0.5 shrink-0 ${isFeatured ? 'text-white' : 'text-blue-600'}`} fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"></path>
        </svg>
        <span>{feature}</span>
      </li>
    ))}
  </ul>

  <a 
    href="#" 
    class={`py-3 px-6 rounded-lg font-bold flex items-center justify-center gap-2 transition-colors ${
      isFeatured 
      ? 'bg-white text-[#0056b3] hover:bg-blue-50' 
      : 'border-2 border-gray-800 text-gray-800 hover:bg-gray-50'
    }`}
  >
    Solicitar cita
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
    </svg>
  </a>
</div>