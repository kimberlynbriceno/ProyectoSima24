---
// Props para que cada tarjeta tenga su propio icono, título y texto
const { title, description, href } = Astro.props;
---
<div class="bg-gradient-to-r from-[#EEFFFB] to-[#C3D6F0] shadow-md shadow-blue-200 backdrop-blur-md border  p-8 rounded-2xl flex flex-col h-full hover:shadow-xl transition-all duration-300">
  <div class="mb-6 text-blue-900">
    <slot name="icon" />
  </div>

  <h3 class="text-xl font-black text-black mb-4 font-montserrat">
    {title}
  </h3>

  <p class="text-gray-700 text-sm leading-relaxed mb-8 flex-grow font-montserrat font-medium">
    {description}
  </p>

  <a 
    href={href} 
    class="bg-[#0056b3] text-white py-3 px-6 rounded-lg font-bold flex items-center justify-center gap-2 hover:bg-blue-800 transition-colors w-full mt-auto"
  >
    Solicitar Cotización
    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
      <line x1="7" y1="17" x2="17" y2="7"></line>
      <polyline points="7 7 17 7 17 17"></polyline>
    </svg>
  </a>
</div>