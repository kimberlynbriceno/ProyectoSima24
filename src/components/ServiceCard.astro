---
// Props para que cada tarjeta tenga su propio icono, título y texto
const { title, description, icon } = Astro.props;
---
<div class="p-6 bg-white rounded-xl shadow-sm hover:shadow-md transition-shadow border border-gray-100">
  <div class="text-blue-600 mb-4 text-3xl">
    <i class={icon}></i> </div>
  <h3 class="text-xl font-bold text-blue-900 mb-2">{title}</h3>
  <p class="text-gray-600 text-sm leading-relaxed">
    {description}
  </p>
</div>