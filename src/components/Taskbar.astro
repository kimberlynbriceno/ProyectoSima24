---
// Aquí podrías definir los enlaces en un array para que sea más fácil editarlos luego
const navLinks = [
  
  { name: 'Servicios', href: '#servicios' },
  { name: 'Planes de afiliacion', href: '#Planes de afiliacion' },
  { name: 'Nosotros', href: '#Nosotros' },
  { name: 'Recursos', href: '#recursos' }
];
---

<nav class="sticky top-0 z-50 bg-white/95 backdrop-blur-sm border-b border-gray-100 shadow-sm">
  <div class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between">
    
    <div class="flex items-center gap-2">
      
      <span class="text-2xl font-black text-blue-900 tracking-tighter uppercase"> <img src="/src/image/logo.svg" alt=""></span>
    </div>

    <div class="flex items-center gap-10">
      
      <div class="hidden lg:flex items-center gap-8">
        {navLinks.map(link => (
          <a href={link.href} class="text-sm tracking-wide font-regular text-black hover:text-blue-600 transition-colors">
            {link.name}
          </a>
        ))}
      </div>

      <div class="flex items-center gap-4">
        
        <a href="#afiliate" class="bg-blue-600 text-white px-6 py-2.5 rounded-lg font-bold shadow-lg shadow-blue-200 hover:bg-blue-700 hover:-translate-y-0.5 transition-all text-sm">
         EmergenciaS 24/7
        </a>
        
        <button class="lg:hidden text-gray-600">
          <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7"></path></svg>
        </button>
      </div>

    </div>
  </div>
</nav>
