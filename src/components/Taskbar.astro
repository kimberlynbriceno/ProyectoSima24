---
// Aquí podrías definir los enlaces en un array para que sea más fácil editarlos luego
const navLinks = [
  
  { name: 'Servicios', href: '#servicio' },
  { name: 'Planes de afiliacion', href: '#planes' },
  { name: 'Consultorio', href: '#consultorio' },
  { name: 'Nosotros', href: '#nosotros' },

];
---

<nav class="sticky top-0 z-50 bg-white/95 backdrop-blur-sm border-b border-gray-100 shadow-sm">
  <div class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between">
    
    <div class="flex items-center gap-2">
      
      <span class="text-2xl font-black text-blue-900 tracking-tighter uppercase"> <img src="/images/logo.svg" alt=""></span>
    </div>

    <div class="flex items-center gap-10">
      
      <div class="hidden lg:flex items-center gap-8">
        {navLinks.map(link => (
          <a href={link.href} class="text-sm tracking-wide font-regular text-black hover:text-blue-600 transition-colors">
            {link.name}
          </a>
        ))}
      </div>

      <div class="flex items-center gap-4">
        
        <a href="#afiliate" class="bg-blue-600 text-white px-6 py-2.5 rounded-lg font-bold shadow-lg shadow-blue-200 hover:bg-blue-700 hover:-translate-y-0.5 transition-all text-sm">
         EmergenciaS 24/7
        </a>
        
        <button id="menu-toggle" class="lg:hidden text-gray-600">
          <svg id="hamburger-icon" class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7"></path></svg>
        </button>
      </div>

    </div>
  </div>
  <div id="mobile-menu" class="hidden lg:hidden bg-white border-t border-gray-100 overflow-hidden transition-all duration-300 shadow-xl">
    <div class="flex flex-col p-6 space-y-4">
      {navLinks.map(link => (
        <a href={link.href} class="text-base text-center font-semibold text-gray-800 hover:text-blue-600 border-b border-gray-50 pb-2 link-mobile">
          {link.name}
        </a>
      ))}
    </div>
  </div>
</nav>
<style is:global>
  html {
    scroll-behavior: smooth;
    /* Esto evita que la sección quede tapada por el navbar sticky */
    scroll-padding-top: 80px; 
  }
</style>
<script>
  // Lógica de Astro: Este script se ejecuta en el cliente
  const setupNavbar = () => {
    const btn = document.getElementById('menu-toggle');
    const menu = document.getElementById('mobile-menu');
    const icon = document.getElementById('hamburger-icon');
    const links = document.querySelectorAll('.link-mobile');

    if (btn && menu && icon) {
      btn.addEventListener('click', () => {
        menu.classList.toggle('hidden');
        
        // Cambiamos el icono a una 'X' cuando esté abierto
        const isOpen = !menu.classList.contains('hidden');
        icon.innerHTML = isOpen 
          ? '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />'
          : '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7" />';
      });

      // Cerrar automáticamente al hacer clic en un enlace (para SPA-like feel)
      links.forEach(link => {
        link.addEventListener('click', () => {
          menu.classList.add('hidden');
          icon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7" />';
        });
      });
    }
  };

  // Ejecutar en la carga inicial y tras navegaciones de Astro (si usas View Transitions)
  setupNavbar();
  document.addEventListener('astro:after-swap', setupNavbar);
</script>

