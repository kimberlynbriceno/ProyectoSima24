---
import ServiceCard from '../components/ServiceCard.astro';
import { client as sanity } from '../lib/sanity.mjs';
const servicio = await sanity.fetch(`*[_type == "servicio" && activo != false] | order(nombre asc) {
  _id,
  nombre,
  slug,
  categoria,
  icono,
  descripcion,
  imagen
}`);
console.log("Datos de Sanity:", servicio);
---

<section id="servicio" class="relative py-20 px-6 bg-[#ECF9FF] overflow-hidden">
  <div class="absolute inset-0 z-0 flex justify-center items-center pointer-events-none">
    <img 
      src="/images/mapa-fondo.jpg" 
      alt="Mapa de fondo" 
      class="w-full max-w-5xl object-contain opacity-10" 
    />
  </div>

  <div class="relative z-10 max-w-7xl mx-auto">
    
    <div class="text-center mb-16">
      <h2 class="text-4xl md:text-5xl font-black text-[#0056b3] mb-6 font-montserrat">
        Cobertura Regional y Nacional <span class="text-[#003366]">Inmediata</span>
      </h2>
      <p class="text-gray-600 font-medium max-w-2xl mx-auto font-montserrat">
        Llegamos donde nos necesites por tierra y aire, garantizando soporte vital avanzado en cada kilómetro.
      </p>
    </div>

    <div 
      id="services-scroll-container" 
      class="flex overflow-x-auto pb-8 gap-6 snap-x snap-mandatory scrollbar-hide md:grid md:grid-cols-2 lg:grid-cols-3 md:overflow-visible md:pb-0"
    >
      {servicio.map((item, index) => (
        <div class="min-w-[85%] sm:min-w-[45%] md:min-w-full snap-center flex h-full service-card-wrapper" data-index={index}>
          <ServiceCard
            title={item.nombre}
            description={item.descripcion}
            categoria={item.categoria}
            icono={item.icono}
            href={item.slug ? `/servicios/${item.slug.current}` : '#'}
          >
            </ServiceCard>
        </div>
      ))}

     
      </div>
    </div>

    <div class="flex justify-center gap-2 mt-6 md:hidden">
      {[...Array(servicio.length + 2)].map((_, i) => (
        <div
          class="service-dot w-2 h-2 rounded-full bg-gray-300 transition-all duration-300"
          data-index={i}
        ></div>
      ))}
    </div>
  </div>

  <div class="mt-16 text-center relative z-10">
    <p class="text-blue-800 font-semibold mb-6">
      ¿Necesitas coordinar un traslado de larga distancia? <br class="hidden md:block">Contáctanos ahora mismo.
    </p>
    <a href="https://wa.me/tu-numero" class="inline-flex items-center bg-blue-700 text-white px-8 py-3.5 rounded-lg font-bold hover:bg-blue-800 transition shadow-lg">
      Solicitar Cotización de Traslado
    </a>
  </div>
</section>

  <script>
  function initServicesCarousel() {
    const container = document.getElementById('services-scroll-container');
    const cards = document.querySelectorAll('.service-card-wrapper');
    const dots = document.querySelectorAll('.service-dot');

    if (!container || cards.length === 0 || dots.length === 0) return;

    // Solo activar lógica si estamos en móvil/tablet
    if (window.innerWidth >= 1024) return;

    const options = {
      root: container,
      threshold: 0.6 // Se activa cuando el 60% de la card es visible
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const index = entry.target.getAttribute('data-index');
          
          // Resetear todos los dots
          dots.forEach(dot => {
            dot.classList.remove('bg-[#0056b3]', 'w-4');
            dot.classList.add('bg-gray-300', 'w-2');
          });

          // Activar el dot actual
          if (dots[index]) {
            dots[index].classList.remove('bg-gray-300', 'w-2');
            dots[index].classList.add('bg-[#0056b3]', 'w-4'); // Se vuelve azul y más largo
          }
        }
      });
    }, options);

    cards.forEach((card) => observer.observe(card));
  }

  // Ejecutar al cargar y tras cambios de navegación en Astro
  initServicesCarousel();
  window.addEventListener('resize', initServicesCarousel);
  document.addEventListener('astro:after-swap', initServicesCarousel);
</script>