---
import Layout from '../layouts/Layout.astro';
import Taskbar from '../components/Taskbar.astro';
import site from '../data/site.json';
---

<Layout>
  <Taskbar />
  <main class="max-w-3xl mx-auto px-4 py-16">
    <h1 class="text-3xl font-bold mb-4">About — {site.title}</h1>
    <p class="mb-6">{site.about}</p>

    <h2 class="text-2xl font-semibold mb-2">Features</h2>
    <ul class="list-disc ml-6 mb-6">
      {site.features.map((f) => (
        <li>{f}</li>
      ))}
    </ul>

    <h2 class="text-2xl font-semibold mb-2">Team</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      {site.team.map((member) => (
        <div class="p-4 bg-white border rounded-md">
          <div class="font-semibold">{member.name}</div>
          <div class="text-sm text-gray-600">{member.role}</div>
        </div>
      ))}
    </div>
  </main>
</Layout>
