---
import Layout from '../layouts/Layout.astro';
import site from '../data/site.json';
---

<Layout>
  <div class="max-w-2xl mx-auto px-4 py-20">
    <h1 class="text-3xl font-bold mb-4">Action Page</h1>
    <p class="mb-6">This page can use dynamic data — here are the site features:</p>
    <ul class="list-disc ml-6 mb-6">
      {site.features.map((f) => (
        <li>{f}</li>
      ))}
    </ul>
    <a href="/" class="text-blue-600 hover:underline">Back home</a>
  </div>
</Layout>
