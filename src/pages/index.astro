---
import Layout from '../layouts/Layout.astro';
import Taskbar from '../components/Taskbar.astro';
import Hero from '../components/Hero.astro';
import ServiceCard from '../components/ServiceCard.astro';
import PricingSection from '../pages/PricingSection.astro';
---

<Layout>
  <Taskbar />
  <main>
    <Hero />
    <section class="relative py-20 px-6 bg-[#ECF9FF] overflow-hidden">
  
  <div class="absolute inset-0 z-0 flex justify-center items-center pointer-events-none">
    <img 
      src="/src/image/mapa-fondo.jpg" 
      alt="" 
      class="w-full max-w-5xl object-contain opacity-10" 
    />
  </div>

  <div class="relative z-10 max-w-7xl mx-auto">
    
    <div class="text-center mb-16">
      <h2 class="text-4xl md:text-5xl font-black text-[#0056b3] mb-6 font-montserrat">
        Cobertura Regional y Nacional Inmediata
      </h2>
      <p class="text-gray-600 font-medium max-w-2xl mx-auto font-montserrat">
        Llegamos donde nos necesites por tierra y aire, garantizando soporte vital avanzado en cada kilómetro.
      </p>
    </div>
 <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
  
    <ServiceCard 
      title="Infraestructura UCI"
      description="Nuestras ambulancias UCI están equipadas para traslados de alta complejidad y soporte vital avanzado. Cobertura total en el Eje Panamericano (Tucaní, La Tendida) y Sur del Lago (Santa Bárbara).">
    <svg slot="icon"
  xmlns="http://www.w3.org/2000/svg" 
  width="40" 
  height="40" 
  viewBox="0 0 24 24" 
  fill="none" 
  stroke="#0066FF" 
  stroke-width="2" 
  stroke-linecap="round" 
  stroke-linejoin="round" 
  class="lucide lucide-ambulance"
>
  <path d="M10 10H6" />
  <path d="M14 18V6a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v11a1 1 0 0 0 1 1h2" />
  <path d="M19 18h2a1 1 0 0 0 1-1v-3.28a1 1 0 0 0-.684-.948l-4.83-1.583a2 2 0 0 1-1.382-1.902V6a2 2 0 0 0-2-2h-2" />
  <circle cx="7" cy="18" r="2" />
  <circle cx="17" cy="18" r="2" />
  <path d="M8 14h4" />
</svg>
    </ServiceCard>

    <ServiceCard 
      title="Traslado Aéreo"
      description="Contamos con diferentes aviones adaptados a las necesidades del paciente para traslados nacionales. Conexión rápida desde San Cristóbal o Mérida hacia centros especializados en todo el país.">
    <svg slot="icon"
  xmlns="http://www.w3.org/2000/svg" 
  width="40" 
  height="40" 
  viewBox="0 0 24 24" 
  fill="none" 
  stroke="#0066FF" 
  stroke-width="2" 
  stroke-linecap="round" 
  stroke-linejoin="round" 
  class="lucide lucide-plane"
>
  <path d="M17.8 19.2 16 11l3.5-3.5C21 6 21.5 4 21 3c-1-.5-3 0-4.5 1.5L13 8 4.8 6.2c-.5-.1-.9.1-1.1.5l-.3.5c-.2.5-.1 1 .3 1.3L9 12l-2 3H4l-1 1 3 2 2 3 1-1v-3l3-2 3.5 5.3c.3.4.8.5 1.3.3l.5-.2c.4-.3.6-.7.5-1.2z" />
</svg>
    </ServiceCard>

    <ServiceCard 
      title="Red de Farmacias Aliadas"
      description="Beneficio de medicinas mediante alianzas con farmacias para todos nuestros clientes en la región. Obtén tranquilidad incluso fuera de El Vigía con facilidades de pago para ti y tu familia. ¡Protección asegurada!">
   <svg slot="icon"
  xmlns="http://www.w3.org/2000/svg" 
  width="40" 
  height="40" 
  viewBox="0 0 24 24" 
  fill="none" 
  stroke="#0066FF" 
  stroke-width="2.5" 
  stroke-linecap="round" 
  stroke-linejoin="round" 
  class="lucide lucide-plus-square"
>
  <rect width="18" height="18" x="3" y="3" rx="2" />
  <path d="M8 12h8" />
  <path d="M12 8v8" />
</svg>
    </ServiceCard>

  </div>

  <div class="mt-12 text-center">
    <p class="text-blue-800 font-semibold mb-4">¿Necesitas coordinar un traslado de larga distancia? <br>Contáctanos ahora mismo.</p>
    <a href="https://wa.me/tu-numero" class="inline-flex items-center bg-blue-700 text-white px-8 py-3 rounded-lg font-bold hover:bg-blue-800 transition z-10">
      Solicitar Cotización de Traslado
          
    </a>
  </div>
</section>
    <PricingSection />
  </main>
</Layout>
